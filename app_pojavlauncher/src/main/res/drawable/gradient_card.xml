<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/gradient_card.xml — Card background with silver border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Silver border layer -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#3A3A3A"
                android:endColor="#525252"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Inner dark gradient fill -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape>
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1C1C1C"
                android:endColor="#242424"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>
</layer-list>
