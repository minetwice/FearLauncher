<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Silver to Dark Gray Gradient -->
    <gradient
        android:startColor="#C0C0C0"
        android:endColor="#505050"
        android:angle="135" />
    <!-- Silver Border -->
    <stroke
        android:width="1.5dp"
        android:color="#E0E0E0" />
    <!-- Rounded Corners -->
    <corners android:radius="12dp" />
    <!-- Padding (internal) -->
    <padding
        android:left="16dp"
        android:top="14dp"
        android:right="16dp"
        android:bottom="14dp" />
</shape>
