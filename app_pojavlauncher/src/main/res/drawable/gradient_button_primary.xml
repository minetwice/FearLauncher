<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="@color/fear_secondary"
                android:endColor="@color/fear_primary"
                android:angle="135" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="@color/fear_primary"
                android:endColor="@color/fear_secondary"
                android:angle="135" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
