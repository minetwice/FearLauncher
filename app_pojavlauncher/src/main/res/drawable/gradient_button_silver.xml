<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/gradient_button_silver.xml — Silver secondary button -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#2A2A2A"
                android:endColor="#3A3A3A"/>
            <stroke android:width="1dp" android:color="#888888"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <!-- Silver border glow -->
            <item>
                <shape>
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#555555"
                        android:endColor="#888888"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>
            <!-- Dark fill -->
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
                <shape>
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#1E1E1E"
                        android:endColor="#2C2C2C"/>
                    <corners android:radius="11dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
