<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFB74D">
    <item android:id="@android:id/mask">
        <shape>
            <corners android:radius="8dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape>
                    <gradient
                        android:startColor="#F57C00"
                        android:endColor="#FFB74D"
                        android:angle="135" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item>
                <layer-list>
                    <item>
                        <shape>
                            <gradient
                                android:startColor="#FFB74D"
                                android:centerColor="#FF9800"
                                android:endColor="#F57C00"
                                android:angle="135" />
                            <corners android:radius="8dp" />
                        </shape>
                    </item>
                    <!-- Gloss overlay -->
                    <item android:top="1dp" android:left="1dp" android:right="1dp">
                        <shape>
                            <gradient
                                android:startColor="#60FFFFFF"
                                android:endColor="#00FFFFFF"
                                android:angle="270" />
                            <corners android:radius="7dp" />
                        </shape>
                    </item>
                </layer-list>
            </item>
        </selector>
    </item>
</ripple>
