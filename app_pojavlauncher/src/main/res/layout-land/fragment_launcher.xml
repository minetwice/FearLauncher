<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_20sdp"
        android:paddingTop="@dimen/_12sdp"
        android:paddingBottom="@dimen/_80sdp">

        <!-- ========================================= -->
        <!-- TOP HEADER: ACCOUNT AVATAR + USERNAME    -->
        <!-- ========================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar + Name (Like Official Launcher) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/account_avatar"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:src="@drawable/ic_account_circle"
                    android:background="@drawable/avatar_bg"
                    android:padding="@dimen/_4sdp"
                    android:contentDescription="Account Avatar" />

                <TextView
                    android:id="@+id/account_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:text="FearUser"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Settings Button -->
            <ImageButton
                android:id="@+id/setting_button_top"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:src="@drawable/ic_px_sliders"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/primary_text"
                android:padding="@dimen/_8sdp"
                android:scaleType="fitCenter"
                android:contentDescription="Settings" />

        </LinearLayout>

        <!-- ========================================= -->
        <!-- QUICK PLAY CARD (Hero Section)           -->
        <!-- ========================================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/fear_surface_variant"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_20sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK PLAY"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="Latest release"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/version_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.21.1"
                    android:textColor="#FFAA00"
                    android:textSize="@dimen/_28ssp"
                    android:textStyle="bold" />

                <!-- PLAY BUTTON (Gold Accent) -->
                <com.kdt.mcgui.MineButton
                    android:id="@+id/play_button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:text="PLAY"
                    android:textAllCaps="true"
                    android:textSize="@dimen/_16ssp"
                    android:textColor="@color/fear_on_primary"
                    android:backgroundTint="#FFAA00"
                    android:stateListAnimator="@animator/button_scale" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========================================= -->
        <!-- WHAT'S NEW CARD                          -->
        <!-- ========================================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/fear_surface_variant"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_20sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHAT'S NEW"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="THE FUTURE OF MINECRAFT'S DEVELOPMENT"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="September 9, 2024"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========================================= -->
        <!-- RECENT INSTALLATIONS                     -->
        <!-- ========================================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="Recent Installations"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Card 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">

                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_java"
                            android:tint="#C0C0C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear Vanilla"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.20.4"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">

                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_file_dl"
                            android:tint="#C0C0C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear Modded"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.19.2"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">

                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_home"
                            android:tint="#C0C0C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear SMP"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.20.1"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ========================================= -->
        <!-- QUICK ACTIONS (सारे पुराने Options यहाँ)  -->
        <!-- ========================================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="QUICK ACTIONS"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:columnCount="2"
            android:rowCount="4">

            <!-- 1. Installations -->
            <androidx.cardview.widget.CardView
                android:id="@+id/installations_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_java"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Installations"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. Mods -->
            <androidx.cardview.widget.CardView
                android:id="@+id/mods_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_file_dl"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Mods"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Skins -->
            <androidx.cardview.widget.CardView
                android:id="@+id/skins_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_edit"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Skins"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. Custom Controls -->
            <androidx.cardview.widget.CardView
                android:id="@+id/custom_control_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_gamepad"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Controls"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 5. Share Logs -->
            <androidx.cardview.widget.CardView
                android:id="@+id/share_logs_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_sharelog"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Share Logs"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 6. Execute JAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/install_jar_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_java_run"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Execute JAR"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 7. Settings -->
            <androidx.cardview.widget.CardView
                android:id="@+id/settings_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_sliders"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Settings"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 8. Open Directory -->
            <androidx.cardview.widget.CardView
                android:id="@+id/open_files_button"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:stateListAnimator="@animator/button_scale">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_folder"
                        android:tint="#C0C0C0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Open Directory"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ========================================= -->
        <!-- VERSION SELECTOR + EDIT PROFILE           -->
        <!-- ========================================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/background_bottom_bar"
            android:padding="@dimen/_8sdp"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_4sdp">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="0dp"
                android:layout_height="@dimen/_52sdp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableEnd="@drawable/spinner_arrow"
                app:drawableEndSize="@dimen/padding_heavy"
                app:drawableStartIntegerScaling="true"
                app:drawableStartSize="@dimen/_36sdp"
                app:drawableEndPadding="@dimen/_1sdp" />

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="@dimen/_52sdp"
                android:layout_height="@dimen/_52sdp"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/ic_px_edit"
                android:tint="@color/primary_text"
                android:contentDescription="Edit Profile" />

        </LinearLayout>

        <!-- ========================================= -->
        <!-- FOOTER                                   -->
        <!-- ========================================= -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_32sdp"
            android:text="Fear Launcher v1.0.0"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_11ssp"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Made with ❤️ by Fear Team"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_10ssp"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="No tasks running"
            android:textColor="#00E676"
            android:textSize="@dimen/_12ssp"
            android:gravity="center"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Everything is up to date!"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_10ssp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
