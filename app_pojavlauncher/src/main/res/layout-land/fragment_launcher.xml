<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_20sdp"
        android:paddingTop="@dimen/_12sdp"
        android:paddingBottom="@dimen/_80sdp">

        <!-- ===== TOP HEADER: HAMBURGER + WELCOME ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- ☰ Hamburger Button (Small, Top-Left) -->
            <ImageButton
                android:id="@+id/hamburger_menu_button"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:src="@drawable/ic_hamburger"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/_8sdp"
                android:scaleType="fitCenter"
                android:contentDescription="Menu" />

            <!-- Welcome Text Group -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_8sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back,"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_14ssp" />

                <TextView
                    android:id="@+id/welcome_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FearUser!"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_22ssp"
                    android:textStyle="bold"
                    android:fontFamily="@font/minecraft_ten" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to explore your world?"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp" />

            </LinearLayout>
        </LinearLayout>

        <!-- ===== HERO SECTION (Big Play Card) ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/fear_surface_variant"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_20sdp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FEAR LAUNCHER"
                    android:textColor="@color/fear_primary"
                    android:textSize="@dimen/_28ssp"
                    android:textStyle="bold"
                    android:fontFamily="@font/minecraft_ten"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="YOUR WORLD. YOUR ADVENTURE."
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_12ssp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:text="Jump into endless possibilities and create your own story."
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp"
                    android:gravity="center" />

                <!-- PLAY NOW BUTTON -->
                <com.kdt.mcgui.MineButton
                    android:id="@+id/play_button"
                    android:layout_width="200dp"
                    android:layout_height="@dimen/_56sdp"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:text="▶ PLAY NOW"
                    android:textAllCaps="false"
                    android:textSize="@dimen/_16ssp"
                    android:textColor="@color/fear_on_primary"
                    android:backgroundTint="@color/fear_primary"
                    app:cornerRadius="28dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== RECENT INSTALLATIONS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="Recent Installations"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Card 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">
                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_java"
                            android:tint="@color/fear_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear Vanilla"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.20.4"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">
                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_file_dl"
                            android:tint="@color/fear_secondary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear Modded"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.19.2"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/fear_surface_variant"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/_12sdp">
                        <ImageView
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:src="@drawable/ic_px_home"
                            android:tint="@color/fear_tertiary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_4sdp"
                            android:text="Fear SMP"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_12ssp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.20.1"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ===== QUICK ACTIONS (All Old Buttons Here) ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_24sdp"
            android:text="Quick Actions"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            android:columnCount="2"
            android:rowCount="2">

            <!-- 1. Wiki / News Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/news_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_book"
                        android:tint="@color/fear_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Wiki"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. Discord / Social Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/social_media_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_discord"
                        android:tint="@color/fear_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Discord"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Custom Controls -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/custom_control_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_gamepad"
                        android:tint="@color/fear_tertiary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Custom Controls"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. Share Logs -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_6sdp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/fear_surface_variant"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/share_logs_button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:src="@drawable/ic_px_sharelog"
                        android:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:text="Share Logs"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_11ssp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ===== FOOTER ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_32sdp"
            android:text="Fear Launcher v1.0.0"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_11ssp"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Made with ❤️ by Fear Team"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_10ssp"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="No tasks running"
            android:textColor="@color/fear_secondary"
            android:textSize="@dimen/_12ssp"
            android:gravity="center"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Everything is up to date!"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_10ssp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
