<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Sheet: Account Manager -->
<!-- Place at: res/layout/fragment_account_manager.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/background_card"
    android:paddingBottom="@dimen/_24sdp">

    <!-- Drag Handle -->
    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_4sdp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@color/background_overlay"
        android:layout_marginBottom="@dimen/_8sdp"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/_20sdp"
        android:paddingTop="@dimen/_8sdp"
        android:paddingBottom="@dimen/_16sdp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accounts"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_18ssp"
            android:textStyle="bold"/>

        <!-- Add Account Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/_13ssp"
            app:backgroundTint="#FF4500"
            app:cornerRadius="8dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/background_overlay"
        android:layout_marginHorizontal="@dimen/_16sdp"/>

    <!-- Account List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/account_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:nestedScrollingEnabled="false"
        android:paddingTop="@dimen/_8sdp"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_account_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/_24sdp"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            android:src="@drawable/ic_account_circle"
            android:tint="@color/secondary_text"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="No accounts added yet"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_14ssp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Tap '+ Add' to add your account"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_12ssp"/>

    </LinearLayout>

</LinearLayout>
