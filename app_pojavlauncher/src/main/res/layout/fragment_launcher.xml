<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_gradient_bg">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/top_bar_infumia"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_50sdp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/_20sdp"
        android:background="#20000000"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INFUMIA"
            android:textColor="@color/fear_primary"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" LAUNCHER"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_10ssp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tab_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anasayfa"
            android:textColor="@color/fear_primary"
            android:textSize="@dimen/_9ssp"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_servers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sunucular"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_9ssp"
            android:layout_marginHorizontal="@dimen/_12sdp" />

        <TextView
            android:id="@+id/tab_skin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skin"
            android:textColor="@color/secondary_text"
            android:textSize="@dimen/_9ssp"
            android:layout_marginHorizontal="@dimen/_12sdp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/hamburger_menu_icon"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_px_sliders"
            app:tint="@color/secondary_text"
            android:layout_marginStart="@dimen/_10sdp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Content Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/_24sdp"
        android:paddingVertical="@dimen/_12sdp"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/top_bar_infumia"
        app:layout_constraintBottom_toTopOf="@+id/bottom_controls_infumia">

        <!-- Left News Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:layout_marginEnd="@dimen/_12sdp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/premium_glass_bg">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@mipmap/ic_launcher_foreground"
                    android:scaleType="centerCrop"
                    android:alpha="0.2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="@dimen/_20sdp"
                    android:background="@drawable/premium_gradient_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.1 GÜNCELLEMESI"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/_18ssp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="Experience the new Infumia UI with orange glossy accents and improved layout placement for a professional feel."
                        android:textColor="@color/secondary_text"
                        android:textSize="@dimen/_10ssp"
                        android:maxLines="3" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Right Server Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp"
                android:background="@drawable/premium_glass_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En iyi 4 sunucu"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/_12sdp"
                    android:background="#1AFFFFFF" />

                <!-- Mock items to simulate the server list in the image -->
                <include layout="@layout/item_simple_list_1" />
                <include layout="@layout/item_simple_list_1" />
                <include layout="@layout/item_simple_list_1" />
                <include layout="@layout/item_simple_list_1" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Bottom Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_controls_infumia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_24sdp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- User Section -->
        <LinearLayout
            android:id="@+id/account_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/_8sdp"
            android:background="@drawable/premium_glass_bg"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/account_avatar"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:src="@drawable/ic_account_circle"
                android:background="@drawable/avatar_bg"
                android:padding="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_10sdp">

                <TextView
                    android:id="@+id/account_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Y.E.P"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/account_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Local Account"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_8ssp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Launcher Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="@dimen/_100sdp"
                android:layout_height="@dimen/_42sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:background="@drawable/premium_glass_bg" />

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="@dimen/_42sdp"
                android:layout_height="@dimen/_42sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:src="@drawable/ic_px_edit"
                android:background="@drawable/premium_glass_bg"
                app:tint="@color/fear_primary" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/play_button"
                android:layout_width="@dimen/_120sdp"
                android:layout_height="@dimen/_42sdp"
                android:text="PLAY"
                android:textColor="#000000"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold"
                android:background="@drawable/premium_button_bg" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Version Text for MainMenuFragment -->
    <TextView
        android:id="@+id/version_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Settings Tray -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settings_tray"
        android:layout_width="@dimen/_260sdp"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="0dp"
        app:cardElevation="32dp"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/_20sdp"
            android:background="@drawable/premium_gradient_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MENU"
                android:textColor="@color/fear_primary"
                android:textSize="@dimen/_10ssp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="@dimen/_24sdp" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/install_jar_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="MODS"
                android:drawableStart="@drawable/ic_px_java_run" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/custom_control_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="INPUT"
                android:drawableStart="@drawable/ic_px_gamepad" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/open_files_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="FILES"
                android:drawableStart="@drawable/ic_px_folder" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#20FFFFFF" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_settings"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="SETTINGS"
                android:drawableStart="@drawable/ic_px_sliders" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_runtime"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="RUNTIME"
                android:drawableStart="@drawable/ic_px_runtime_mgr" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_accounts"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="ACCOUNTS"
                android:drawableStart="@drawable/ic_account_circle" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/share_logs_button_tray"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="LOGS"
                android:drawableStart="@drawable/ic_px_sharelog" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/tray_close"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_40sdp"
                android:text="CLOSE"
                android:background="@drawable/premium_button_bg" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>