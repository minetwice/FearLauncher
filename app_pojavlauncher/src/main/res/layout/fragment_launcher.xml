<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/premium_gradient_bg"
    android:animateLayoutChanges="true">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/_12sdp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/account_section"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/account_avatar"
                android:layout_width="@dimen/_36sdp"
                android:layout_height="@dimen/_36sdp"
                android:src="@drawable/ic_account_circle"
                android:background="@drawable/avatar_bg"
                android:padding="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_8sdp">

                <TextView
                    android:id="@+id/account_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guest"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/account_type_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Local Account"
                    android:textColor="#BDBDBD"
                    android:textSize="@dimen/_8ssp" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/hamburger_menu_icon"
            android:layout_width="@dimen/_36sdp"
            android:layout_height="@dimen/_36sdp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_px_sliders"
            app:tint="@color/fear_primary" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/quick_play_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_40sdp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_controls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/_24sdp"
            android:gravity="center"
            android:background="@drawable/premium_glass_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEAR LAUNCHER"
                android:textColor="@color/fear_primary"
                android:textSize="@dimen/_10ssp"
                android:textStyle="bold"
                android:letterSpacing="0.4" />

            <TextView
                android:id="@+id/version_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="FABRIC 1.21.1"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/play_button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_52sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:text="PLAY"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold"
                android:background="@drawable/premium_button_bg" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/premium_glass_bg"
            android:padding="6dp">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="0dp"
                android:layout_height="@dimen/_44sdp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:paddingHorizontal="12dp" />

            <ImageButton
                android:id="@+id/edit_profile_button"
                android:layout_width="@dimen/_38sdp"
                android:layout_height="@dimen/_38sdp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/premium_button_bg"
                android:src="@drawable/ic_px_edit"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="3">

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/install_jar_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:text="JAVA MODS"
                android:drawableStart="@drawable/ic_px_java_run" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/custom_control_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:text="CONTROLS"
                android:drawableStart="@drawable/ic_px_gamepad" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/open_files_button"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:text="STORAGE"
                android:drawableStart="@drawable/ic_px_folder" />

        </GridLayout>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/settings_tray"
        android:layout_width="@dimen/_240sdp"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="0dp"
        app:cardElevation="32dp"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/_20sdp"
            android:background="@drawable/premium_gradient_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMAND CENTER"
                android:textColor="@color/fear_primary"
                android:textSize="@dimen/_10ssp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="@dimen/_24sdp" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_settings"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="SETTINGS"
                android:drawableStart="@drawable/ic_px_sliders" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_runtime"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="JAVA RUNTIMES"
                android:drawableStart="@drawable/ic_px_runtime_mgr" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/tray_accounts"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="ACCOUNTS"
                android:drawableStart="@drawable/ic_account_circle" />

            <com.kdt.mcgui.LauncherMenuButton
                android:id="@+id/share_logs_button_tray"
                style="@style/LauncherMenuButton.Universal"
                android:layout_width="match_parent"
                android:text="DEBUG LOGS"
                android:drawableStart="@drawable/ic_px_sharelog" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.kdt.mcgui.MineButton
                android:id="@+id/tray_close"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_40sdp"
                android:text="CLOSE"
                android:background="@drawable/premium_button_bg" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>