<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/control_button_color</item>
        <item name="colorPrimaryDark">@color/background_status_bar</item>
        <item name="colorAccent">@color/icon_outline_color</item>
        <item name="android:windowBackground">@color/background_app</item>
    </style>
    
    <!-- Rounded button style with ripple -->
    <style name="RoundedButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_silver_ripple</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>
    
    <!-- Other existing styles from original (if needed) -->
    <style name="ControlButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">8dp</item>
        <item name="android:textColor">@color/primary_text</item>
    </style>
</resources>
