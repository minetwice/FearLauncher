<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="FearPreferenceTheme" parent="PreferenceThemeOverlay.v14.Material">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:colorBackground">@android:color/transparent</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <item name="android:divider">@android:color/transparent</item>
    </style>

    <style name="FearSwitchTheme" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="colorControlActivated">@color/silver_light</item>
        <item name="colorSwitchThumbNormal">@color/silver_dark</item>
    </style>

    <style name="Theme.FearLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/fear_primary</item>
        <item name="colorOnPrimary">@color/fear_on_primary</item>
        <item name="colorSecondary">@color/fear_secondary</item>
        <item name="colorTertiary">@color/fear_tertiary</item>
        <item name="android:colorBackground">@color/background_app</item>
        <item name="android:windowBackground">@drawable/premium_gradient_bg</item>
        <item name="preferenceTheme">@style/FearPreferenceTheme</item>
        <item name="alertDialogTheme">@style/FearAlertDialogTheme</item>
    </style>

    <style name="FearAlertDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">@drawable/premium_gradient_bg</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorAccent">@color/silver_main</item>
    </style>

    <style name="LauncherMenuButton" parent="">
    </style>

    <style name="LauncherMenuButton.Universal">
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:background">@drawable/premium_button_bg</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">2dp</item>
        <item name="android:background">@color/silver_dark</item>
    </style>
</resources>