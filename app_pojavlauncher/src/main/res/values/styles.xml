<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ========================================== -->
    <!-- FEAR LAUNCHER MAIN THEME                   -->
    <!-- ========================================== -->
    <style name="Theme.FearLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <item name="colorPrimary">@color/fear_primary</item>
        <item name="colorOnPrimary">@color/fear_on_primary</item>
        <item name="colorSecondary">@color/fear_secondary</item>
        <item name="colorTertiary">@color/fear_tertiary</item>
        
        <item name="android:colorBackground">@color/background_app</item>
        <item name="colorSurface">@color/fear_surface</item>
        <item name="colorSurfaceVariant">@color/fear_surface_variant</item>
        
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColorPrimary">@color/primary_text</item>
        <item name="android:textColorSecondary">@color/secondary_text</item>
        <item name="android:textColorHint">@color/secondary_text</item>
    </style>

    <!-- ========================================== -->
    <!-- PREFERENCE THEME (Settings) – Minimal      -->
    <!-- ========================================== -->
    <style name="FearPreferenceTheme" parent="@style/PreferenceThemeOverlay.v14.Material">
        <!-- Background for the preference screen -->
        <item name="android:colorBackground">@color/background_app</item>
        
        <!-- Category style with custom text color -->
        <item name="android:preferenceCategoryStyle">@style/FearPreferenceCategory</item>
        
        <!-- Divider color -->
        <item name="android:listDivider">@color/silver_dark</item>
        <item name="android:dividerHeight">1dp</item>
    </style>

    <!-- Preference Category – Silver text + Shadow -->
    <style name="FearPreferenceCategory" parent="@style/Preference.Category.Material">
        <item name="android:textColor">@color/silver_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:shadowColor">#80000000</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <!-- ========================================== -->
    <!-- HELPER STYLES (for general UI)              -->
    <!-- ========================================== -->
    <style name="LauncherMenuButton" parent="Widget.AppCompat.Button">
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>
    <style name="LauncherMenuButton.Universal" parent="LauncherMenuButton">
        <item name="android:layout_height">@dimen/_66sdp</item>
    </style>
    <style name="LauncherFragment_Divider">
        <item name="android:layout_width">@dimen/padding_tiny</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">@color/divider</item>
    </style>
    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">?android:attr/listDivider</item>
    </style>
</resources>
