<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Theme -->
    <style name="AppTheme" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.v14.Material</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <!-- FEAR LAUNCHER Modern Theme (MaterialComponents) -->
    <style name="Theme.FearLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/fear_primary</item>
        <item name="colorOnPrimary">@color/fear_on_primary</item>
        <item name="colorSecondary">@color/fear_secondary</item>
        <item name="colorTertiary">@color/fear_tertiary</item>
        
        <!-- Surfaces -->
        <item name="android:colorBackground">@color/background_app</item>
        <item name="colorSurface">@color/fear_surface</item>
        <item name="colorSurfaceVariant">@color/fear_surface_variant</item>
        
        <!-- Typography -->
        <item name="fontFamily">@font/fear_display_fallback</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <!-- Card Style for Dashboard -->
    <style name="FearCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/fear_surface_variant</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/background_overlay</item>
    </style>

    <!-- Big Play Button (FIXED: Compatible with all Material versions) -->
    <style name="FearPlayButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">64dp</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:textSize">18sp</item>
        <item name="backgroundTint">@color/fear_primary</item>
        <item name="android:textColor">@color/fear_on_primary</item>
    </style>

    <!-- Legacy Pojav Styles (Preserved for Compatibility) -->
    <style name="LauncherFragment_Divider">
        <item name="android:layout_width">@dimen/padding_tiny</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="LauncherMenuButton" parent="Widget.AppCompat.Button">
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="LauncherMenuButton.Universal" parent="LauncherMenuButton">
        <item name="android:layout_height">@dimen/_66sdp</item>
    </style>

    <style name="ThickDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:background">?android:attr/listDivider</item>
    </style>

    <item name="dimension_tracker" type="id" />
    <style name="DimensionTracker">
        <item name="android:id">@id/dimension_tracker</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>
</resources>
